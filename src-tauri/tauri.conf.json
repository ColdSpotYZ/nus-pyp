{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NUS Exam Papers",
  "version": "0.1.0",
  "identifier": "com.coldspot.nuspyp",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build && npm run prepare:cli-bundle",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "NUS Exam Papers",
        "width": 1480,
        "height": 980,
        "minWidth": 1180,
        "minHeight": 820
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/cli/"
    ],
    "windows": {
      "wix": {
        "fragmentPaths": [
          "./windows/fragments/cli-path.wxs"
        ],
        "componentRefs": [
          "CliPathEnvironment"
        ]
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
