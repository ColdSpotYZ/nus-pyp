<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Fragment>
    <DirectoryRef Id="INSTALLDIR">
      <Component Id="CliPathEnvironment" Guid="*">
        <Environment
          Id="NusExamPapersCliPath"
          Name="PATH"
          Action="set"
          Part="last"
          System="no"
          Value="[INSTALLDIR]resources\cli"
        />
        <RegistryValue
          Root="HKCU"
          Key="Software\Coldspot\NUS Exam Papers"
          Name="CliPathInstalled"
          Type="integer"
          Value="1"
          KeyPath="yes"
        />
      </Component>
    </DirectoryRef>
  </Fragment>
</Wix>
