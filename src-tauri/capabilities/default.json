{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main", "auth-window"],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:default",
    "fs:write-files",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$HOME/**/*" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$DOWNLOAD/**/*" }
      ]
    },
    "opener:default"
  ]
}
